# Subtrees that are not Go code; keeping them out of Bazel's package
# scan avoids spurious BUILD-file generation. Note that nvcf/ and
# ratelimiter/ are NOT excluded: they contain pre-generated .pb.go files
# imported by proxy/. See gazelle directives in root BUILD.bazel.
local
vault

# Vendored vault api/sdk auth providers that ess-agent does not link.
# Only kubernetes auth is wired up via dependency/client_set.go; the
# other backends drag in heavy cloud-sdk deps (aws-sdk-go, cloud.google,
# go-ldap, etc.) that would otherwise have to be carried in MODULE.bazel
# just to satisfy `bazel build //...`. Add the directory back here when
# a new auth backend is genuinely needed.
api/auth/approle
api/auth/aws
api/auth/azure
api/auth/gcp
api/auth/ldap
api/auth/userpass
sdk/helper/ldaputil
