load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "gateway_config",
    srcs = ["gateway_config.go"],
    importpath = "ai-api-gateway-service/gateway_config",
    visibility = ["//visibility:public"],
    deps = ["//internal/reloadableconfig"],
)

alias(
    name = "go_default_library",
