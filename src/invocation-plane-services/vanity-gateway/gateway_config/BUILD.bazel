)

go_test(
    name = "gateway_config_test",
    srcs = ["gateway_config_test.go"],
    embed = [":gateway_config"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
