load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "tools",
    srcs = [
        "call.go",
        "call_id.go",
        "calls.go",
        "config.go",
        "envelope.go",
        "glm.go",
        "kimi.go",
        "minimax.go",
        "parse_bare_array.go",
        "parse_json.go",
        "parse_native.go",
    ],
    embedsrcs = [
        "embed/bare_array_call_schema.json",
        "embed/bare_array_parameters_call_schema.json",
        "embed/bare_call_schema.json",
        "embed/generic_tool_call_sysprompt.tmpl",
        "embed/parallel_call_schema.json",
        "embed/single_call_schema.json",
    ],
    importpath = "github.com/NVIDIA/nvcf/src/invocation-plane-services/llm-gateway/templating/tools",
    visibility = ["//visibility:public"],
    deps = [
        "//internal/container/set",
        "//internal/encoding/json",
        "//internal/must",
