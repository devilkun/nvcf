        "parse_native_internals_test.go",
        "parse_native_test.go",
        "tool_call_parsing_test.go",
    ],
    embed = [":tools"],
    deps = [
        "//internal/ptr",
        "//models",
        "//templating/prompt",
        "//templating/testhelpers",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
