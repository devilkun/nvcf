load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "ratelimit",
    srcs = [
        "admission.go",
        "defaults.go",
        "nats_synchronizer.go",
        "nop_limiter.go",
        "olric_store.go",
        "pubsub_consumer.go",
        "pubsub_synchronizer.go",
        "ratelimit.go",
        "ratelimit_result.go",
        "resources.go",
        "sync_events.go",
        "synchronizer.go",
    ],
    importpath = "github.com/NVIDIA/nvcf/src/invocation-plane-services/llm-gateway/ratelimit",
    visibility = ["//visibility:public"],
    deps = [
        "//pubsub",
        "//telemetry",
        "@com_github_nats_io_nats_go//:nats_go",
        "@com_github_olric_data_olric//:olric",
        "@com_github_rs_zerolog//:zerolog",
