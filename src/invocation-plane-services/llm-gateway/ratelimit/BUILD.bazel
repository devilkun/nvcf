        "ratelimit_result_test.go",
        "ratelimit_sync_test.go",
        "ratelimit_test.go",
        "sync_events_test.go",
    ],
    embed = [":ratelimit"],
    deps = [
        "//config",
        "//ratelimit/ratelimitmock",
        "//util",
        "@com_github_nats_io_nats_go//:nats_go",
        "@com_github_stretchr_testify//require",
        "@com_github_stretchr_testify//suite",
        "@org_uber_go_mock//gomock",
    ],
)
