# nvidia-lpu-vendor/ is the legacy mise-bootstrap-populated mirror of
# private nvidia-lpu Go modules. With the Bazel pivot, Gazelle's
# go_deps fetches those modules directly from the proxy; the local
# bootstrap mirror is dev-time only and not part of the Bazel build.
# Excluding here keeps Gazelle from finding two copies of the same
# packages (which would emit conflicting BUILD targets).
nvidia-lpu-vendor

# Kustomize manifests are Helm/k8s overlays; no Go code.
kustomize
