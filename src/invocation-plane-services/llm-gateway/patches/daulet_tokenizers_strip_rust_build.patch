+load("@io_bazel_rules_go//go:def.bzl", "go_library")
 
+# Replaces upstream daulet/tokenizers BUILD.bazel which relies on Cargo
+# + rust_static_library. We provide libtokenizers.a separately via the
+# `libtokenizers_linux_{amd64,arm64}` http_archives in llm-api-gateway's
