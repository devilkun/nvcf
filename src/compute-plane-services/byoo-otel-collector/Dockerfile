#####
### Stage 1: Build binaries for byoo-otel-collector
#####

FROM --platform=$BUILDPLATFORM golang:1.26.2-bookworm AS builder

ARG TARGETOS=linux
ARG TARGETARCH

ENV CGO_ENABLED=0

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY cmd ./cmd
COPY internal ./internal

RUN GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -a -o /app/bin/byoo-otel-collector ./cmd/byoo-otel-collector

####
### Stage 2: Build OpenTelemetry Collector
###
### Builds the OpenTelemetry Collector binary from the checked-in
### otelcol/ tree (generated by `scripts/regenerate-otelcol.sh` and
### kept in sync by `tools/ci/check-otelcol-generated`). Compared to
### the previous in-Dockerfile invocation of `ocb`, this stage no
### longer downloads ocb itself or has ocb resolve the collector's
### module graph at image build time; only `go mod download` for the
### checked-in collector module runs against the network (cached via
### the standard Go module proxy). The diff on otel version bumps is
### reviewable against the regenerated otelcol/ tree.
####
FROM --platform=$BUILDPLATFORM golang:1.26.2-bookworm AS builder-otelcol

ARG TARGETOS=linux
ARG TARGETARCH

ENV CGO_ENABLED=0

WORKDIR /app

COPY ./otelcol/go.mod ./otelcol/go.sum ./otelcol/
RUN cd otelcol && go mod download

COPY ./otelcol ./otelcol

RUN cd otelcol && \
    GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -a -o /app/output/otelcol-contrib .

####
### Stage 3: Create the final Distroless image for byoo-otel-collector
####
FROM nvcr.io/nvidia/distroless/go:v4.0.4 AS byoo-otel-collector

WORKDIR /app

COPY --from=builder /app/bin/byoo-otel-collector .
COPY --from=builder-otelcol /app/output/otelcol-contrib .

EXPOSE 14357/tcp 14358/tcp 13133/tcp 18888/tcp 19090/tcp

ENTRYPOINT ["/app/byoo-otel-collector"]
